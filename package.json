    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "ngx-theme-stack": "3.9.1",
    "prettier": "^3.8.1",
